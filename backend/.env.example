# Supabase (backend uses the SECRET / service-role key — never the publishable key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Quran text source (startup only) + ASR model
QURAN_API_BASE_URL=https://api.quran.com/api/v4
MODEL_NAME=OdyAsh/faster-whisper-base-ar-quran
PORT=8000

# Comma-separated list of browser origins allowed to call HTTP + WebSocket.
# Dev defaults below; in production set this to your Vercel/site domains only.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional — auto-detected when unset (cuda+float16 on GPU, cpu+int8 otherwise).
# ASR_DEVICE=cuda
# ASR_COMPUTE_TYPE=float16